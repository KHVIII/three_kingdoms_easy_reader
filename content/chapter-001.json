      "characters": [
        {
          "char": "话",
          "pinyin": "huà",
          "definitions": [
            "语言讲话。普通话。",
            "说，谈话别离。茶话会。话不投机。"
          ]
        },
        {
          "char": "说",
          "pinyin": "shuō",
          "definitions": [
            "〈古〉同\"悦\"。",
            "说动别人，使他听从自己的意见说客。游说。",
            "讲话，用话表达意思你说。说到做到。"
          ]
        },
        {
          "char": "天",
          "pinyin": "tiān",
          "definitions": [
            "高空天空。满天星。",
            "高处，顶部天线。天窗。天桥。天头（书页上头的空白部分）。",
            "最，极天好，就这么办。"
          ]
        },
        {
          "char": "下",
          "pinyin": "xià",
          "definitions": [
            "位置在低处，跟\"上\"相对下部。下面的。在楼下。〈引〉",
            "低，跟\"高\"相对，由高到低分个高下。下楼梯。下山坡。〈引〉",
            "攻破，攻克攻下碉堡。已下数城。"
          ]
        },
        {
          "char": "大",
          "pinyin": "dà",
          "definitions": [
            "(象形。甲骨文字形,象人的正面形,有手有脚。大”是汉字部首之一,从大”的字往往与人类或人事有关。本义大小的大”)",
            "形容体积、面积、数量、力量、规模、程度等方面超过一般或超过所比较的对象。与小”相对",
            "大,天大地大人亦大,故大象人形。古文大也,籀文介,改古文亦象人形。凡大人、大夫、太子、太君,皆尊词。--《说文》"
          ]
        },
        {
          "char": "势",
          "pinyin": "shì",
          "definitions": [
            "力量，权力，威力势力。有权有势。人多势众。",
            "力量的趋向势头。趋势。来势凶猛。",
            "自然界的情况、样子地势。山势。"
          ]
        },
        {
          "char": "，",
          "pinyin": null,
          "definitions": null
        },
